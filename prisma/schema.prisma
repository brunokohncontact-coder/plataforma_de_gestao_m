// Plataforma de gestão de carreira para músicos — schema do MVP (F1–F5).
// Banco: SQLite em dev (zero dependência externa). Schema mantido portável p/ Postgres.
// Decisão: valores monetários em CENTAVOS (Int) para evitar erros de ponto flutuante.
// SQLite não tem enums nativos: campos de status/categoria são String validados em
// `src/lib/domain.ts` (uniões de tipo + Zod). Ver DECISIONS.md (D4).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shows        Show[]
  transactions Transaction[]
  contacts     Contact[]
}

/// Show / apresentação. status: proposto | confirmado | realizado | cancelado
model Show {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  date      DateTime
  venue     String?
  city      String?
  status    String   @default("proposto")
  /// Cachê acordado, em centavos.
  feeCents  Int      @default(0)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
  contacts     ShowContact[]

  @@index([userId])
  @@index([userId, date])
}

/// Transação financeira. type: income | expense. status: received | pending.
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String
  category    String
  /// Valor absoluto (sempre positivo), em centavos. O sinal vem de `type`.
  amountCents Int
  date        DateTime
  description String?
  status      String   @default("received")

  /// Vínculo opcional a um show (base da rentabilidade por show — F4).
  showId      String?
  show        Show?    @relation(fields: [showId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
  @@index([showId])
}

/// Contato da indústria. role: venue | promoter | contratante | produtor | imprensa | outro
model Contact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  role      String   @default("outro")
  email     String?
  phone     String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shows     ShowContact[]

  @@index([userId])
}

/// Junção N:N entre Show e Contact.
model ShowContact {
  showId    String
  contactId String
  show      Show    @relation(fields: [showId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([showId, contactId])
  @@index([contactId])
}
