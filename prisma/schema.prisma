// Schema do Palco — ver docs/mvp-scope.md (F1–F5) e DECISIONS.md (D3).
// Banco: SQLite em dev; schema mantido portável para PostgreSQL em produção.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// F1 — Autenticação e workspace do artista
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // Nome artístico / do projeto (workspace). Multiusuário fica para Fase 2,
  // mas já modelamos o conceito para não retrabalhar.
  artistName   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shows        Show[]
  transactions Transaction[]
  contacts     Contact[]
}

// ---------------------------------------------------------------------------
// F2 — Agenda de shows
// ---------------------------------------------------------------------------
// NB: SQLite não suporta `enum` no Prisma. Os campos de status/papel/tipo são
// armazenados como String e validados na aplicação (ver src/lib/enums.ts e Zod).
// Valores de ShowStatus: PROPOSED | CONFIRMED | PERFORMED | CANCELLED
model Show {
  id        String   @id @default(cuid())
  title     String
  date      DateTime
  venue     String?
  city      String?
  status    String   @default("PROPOSED")
  // Cachê acordado (em centavos para evitar erro de ponto flutuante).
  feeCents  Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // F4 — despesas (e eventuais receitas extras) vinculadas a este show.
  transactions Transaction[]

  // F5 — contatos vinculados a este show.
  contacts ShowContact[]

  @@index([userId, date])
}

// ---------------------------------------------------------------------------
// F3 — Finanças: receitas e despesas
// ---------------------------------------------------------------------------
// Valores de TransactionType: INCOME | EXPENSE
model Transaction {
  id          String   @id @default(cuid())
  type        String
  // Valor sempre positivo, em centavos. O sinal é dado por `type`.
  amountCents Int
  category    String
  description String?
  date        DateTime
  // Receita recebida vs. pendente (cobre "contas a receber" — Necessidade #6).
  // Para despesas, indica se já foi paga.
  settled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Vínculo opcional a um show (base da rentabilidade — F4).
  showId String?
  show   Show?   @relation(fields: [showId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([showId])
}

// ---------------------------------------------------------------------------
// F5 — CRM básico de contatos
// ---------------------------------------------------------------------------
// Valores de ContactRole: VENUE | PROMOTER | BOOKER | PRODUCER | PRESS | OTHER
model Contact {
  id        String   @id @default(cuid())
  name      String
  role      String   @default("OTHER")
  email     String?
  phone     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  shows ShowContact[]

  @@index([userId])
}

// Tabela de junção show <-> contato (N:N).
model ShowContact {
  showId    String
  contactId String

  show    Show    @relation(fields: [showId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([showId, contactId])
}
