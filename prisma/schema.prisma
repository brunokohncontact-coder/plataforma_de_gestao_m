// Palco — schema de dados do MVP.
// Banco: SQLite em desenvolvimento (zero dependência externa). Schema mantido
// portável para PostgreSQL em produção (trocar `provider` para "postgresql").
// Ver DECISIONS.md (D3).
//
// NOTA: SQLite no Prisma não suporta `enum` nativo. Por isso os campos de
// "enum" são `String` com valores validados na camada de aplicação (Zod em
// src/lib/validation.ts e constantes em src/lib/domain.ts). Ao migrar para
// PostgreSQL, podem ser promovidos a enums nativos.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── F1: Autenticação e workspace ────────────────────────────────────────────
// Cada usuário é dono do seu workspace. O modelo já isola dados por usuário
// (campo `userId` nas entidades) para não retrabalhar ao introduzir multiusuário.
model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String
  passwordHash String
  artistName   String? // nome artístico / da banda
  // Marca temporal da última troca de senha. Sessões (JWT) emitidas antes
  // desta data são invalidadas — desloga logins antigos ao trocar a senha
  // (ver DECISIONS.md D10).
  passwordChangedAt DateTime @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  shows        Show[]
  transactions Transaction[]
  contacts     Contact[]
  revenueGoals RevenueGoal[]
  passwordResetTokens PasswordResetToken[]
}

// ── Recuperação de senha ────────────────────────────────────────────────────
// Token de uso único para redefinir a senha sem estar logado. Guardamos apenas
// o HASH do token (SHA-256) — o token cru só existe no link enviado ao usuário,
// então um vazamento do banco não expõe tokens utilizáveis. Cada token expira
// (`expiresAt`) e é de uso único (`usedAt` marcado ao ser consumido).
// Ver DECISIONS.md (D259).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String    @unique // SHA-256 hex do token cru
  expiresAt DateTime
  usedAt    DateTime? // marca de consumo (uso único); null = ainda válido
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ── Metas: meta de faturamento anual ────────────────────────────────────────
// Uma meta de receita (faturamento) por ano, por usuário. O progresso é
// calculado na camada de aplicação (src/lib/finance.ts → computeGoalProgress)
// cruzando a meta com a receita já recebida e a projeção de fechamento do ano.
model RevenueGoal {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  year   Int // ano de referência (ex.: 2026)
  amount Int // meta de faturamento no ano, em centavos (sempre > 0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, year])
  @@index([userId])
}

// ── F2: Agenda de shows ─────────────────────────────────────────────────────
// status: PROPOSED | CONFIRMED | PLAYED | CANCELLED  (ver src/lib/domain.ts)
model Show {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String // ex.: "Show no Bar X" ou nome do evento
  date      DateTime
  venue     String? // local
  city      String?
  status    String     @default("PROPOSED")
  fee       Int        @default(0) // cachê acordado, em centavos
  notes     String?

  // Data prometida de pagamento de um cachê em aberto (promise-to-pay). Registrada
  // na cobrança para priorizar o follow-up: promessas furadas (data já passou e o
  // cachê continua em aberto) sobem ao topo da fila de cobrança. Ver DECISIONS.md D94.
  paymentPromisedAt DateTime?

  // Última escolha de contato no seletor "quem cobrar" da tela de cachês a receber:
  // qual dos contatos vinculados o usuário prefere cobrar por este show. Campo `String`
  // simples (não relação) — validado na app contra os contatos alcançáveis do show; um
  // id que deixou de ser alcançável (contato desvinculado / sem canal) é ignorado e a
  // cobrança volta à prioridade padrão por papel. Ver DECISIONS.md D198.
  billingContactId String?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  transactions Transaction[] // despesas/receitas vinculadas (F4)
  contacts     ContactsOnShows[]
  statusEvents ShowStatusEvent[] // histórico de mudanças de status (funil)

  @@index([userId, date])
}

// Histórico de mudanças de status de um show (linha do tempo do funil): cada vez
// que o show é criado ou muda de status (PROPOSED → CONFIRMED → PLAYED, etc.) um
// evento é registrado. Base para a leitura de "quanto tempo ficou em cada etapa"
// e para uma taxa de conversão de verdade no futuro. `fromStatus` é null no evento
// de criação. Ver DECISIONS.md D234.
model ShowStatusEvent {
  id         String   @id @default(cuid())
  showId     String
  show       Show     @relation(fields: [showId], references: [id], onDelete: Cascade)
  userId     String
  fromStatus String? // null = criação do show
  toStatus   String
  createdAt  DateTime @default(now())

  @@index([showId, createdAt])
  @@index([userId])
}

// ── F3: Finanças ────────────────────────────────────────────────────────────
// type: INCOME | EXPENSE  (ver src/lib/domain.ts)
model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String // INCOME | EXPENSE
  description String
  category    String // ex.: cachê, transporte, equipamento, marketing
  amount      Int // valor em centavos (sempre positivo; o sinal vem de `type`)
  date        DateTime
  received    Boolean  @default(true) // recebido/pago vs. pendente (contas a receber)

  // F4: vínculo opcional a um show, para rentabilidade
  showId      String?
  show        Show?    @relation(fields: [showId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, date])
  @@index([showId])
}

// ── F5: CRM de contatos ─────────────────────────────────────────────────────
// role: VENUE | PROMOTER | BOOKER | PRODUCER | PRESS | OTHER  (ver src/lib/domain.ts)
model Contact {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  role      String   @default("OTHER")
  email     String?
  phone     String?
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shows     ContactsOnShows[]

  @@index([userId])
}

// tabela de junção many-to-many Contact <-> Show
model ContactsOnShows {
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  showId    String
  show      Show    @relation(fields: [showId], references: [id], onDelete: Cascade)

  @@id([contactId, showId])
  @@index([showId])
}
