# Banco de dados — SQLite em desenvolvimento (zero dependência externa).
# Em produção, troque o provider do Prisma para postgresql e use uma URL Postgres.
DATABASE_URL="file:./dev.db"

# Segredo para assinar as sessões (cookies). Gere um valor aleatório longo.
# Ex.: openssl rand -hex 32
AUTH_SECRET="dev-secret-change-me-please-0000000000000000000000000000000000000000"
