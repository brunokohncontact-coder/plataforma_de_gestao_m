# Copie para `.env` e ajuste.
# Dev local: um Postgres na máquina (ver `docs/deploy.md`) — mesmo provider do CI/produção.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/palco_dev"
# Usada só pelas migrations (`prisma migrate`/`db push`). Em dev local, mesma URL acima.
# Em produção com connection pooling (PgBouncer/`-pooler`), aponte para a conexão DIRETA.
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/palco_dev"

# Segredo para assinar os cookies de sessão (JWT). Gere um valor longo e aleatório.
AUTH_SECRET="troque-isto-por-um-segredo-longo-e-aleatorio-em-producao"
